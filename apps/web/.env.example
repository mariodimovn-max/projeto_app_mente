# Supabase — credenciais públicas do projeto (Project Settings > API no dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Convites de beta são enviados manualmente pelo administrador via
# supabase.auth.admin.inviteUserByEmail() (Supabase dashboard/CLI), não pelo app.
# O template de e-mail de convite deve redirecionar para:
#   {SITE_URL}/auth/confirm?token_hash={{ .TokenHash }}&type=invite&next=/auth/definir-senha
